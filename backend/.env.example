# Copy to .env (or export in your shell) before starting the backend.

# =============================================================================
# Qwen Cloud (required for AI operations)
# =============================================================================
# DashScope API key from Qwen Cloud (hackathon coupon provides $40 credits)
DASHSCOPE_API_KEY=sk-your-qwen-api-key

# Qwen model selection
# Fast model (email drafting, simple tasks)
QWEN_MODEL_FAST=qwen3.6-flash
# Quality model (CV parsing, scoring, interview)
QWEN_MODEL_QUALITY=qwen3.7-plus
# Reasoning model (orchestrator planning)
QWEN_MODEL_REASONING=qwen3.7-max

# =============================================================================
# Alibaba Cloud Services
# =============================================================================
# AccessKey for Alibaba Cloud (use RAM user, not root account)
ALICLOUD_ACCESS_KEY=LTAIxxx
ALICLOUD_SECRET_KEY=xxx

# OSS bucket for file storage (CVs, PDFs, transcripts)
OSS_ENDPOINT=oss-ap-southeast-1.aliyuncs.com
OSS_BUCKET=recruitai-copilot

# DirectMail for email notifications
DIRECTMAIL_SENDER=noreply@yourdomain.com

# =============================================================================
# Firebase (database + authentication)
# =============================================================================
# Firebase service account file path
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json

# Firebase Web API key (for Firebase Auth)
FIREBASE_WEB_API_KEY=

# Named Firestore database (optional)
FIREBASE_DATABASE_ID=hr-ai-agent

# =============================================================================
# Application Configuration
# =============================================================================
# Secret used to sign JWT access tokens (change in production)
SECRET_KEY=change-me-to-a-long-random-string

# Default admin account (created on first startup)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Rate limiting (requests per minute, 0 = disabled)
RATE_LIMIT_PER_MINUTE=0

# AI cache TTL (seconds, 0 = disabled)
AI_CACHE_TTL_SECONDS=0

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=structured
